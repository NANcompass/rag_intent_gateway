# Environment Configuration for RAG Intent Gateway
# Copy this file to .env and fill in your values

# OpenAI API Configuration
OPENAI_API_KEY=123
OPENAI_BASE_URL=
OPENAI_MODEL=
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=

# Application Configuration
APP_NAME="RAG Intent Gateway"
APP_VERSION=1.0.0
DEBUG=false

# API Configuration
API_PREFIX=/api/v1

# FastAPI Server Configuration
HOST=0.0.0.0
PORT=8000

# MCP Server Configuration (optional)
MCP_HOST=0.0.0.0
MCP_PORT=8022
